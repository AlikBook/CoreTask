### Test REST API Endpoints

### Variables
@baseUrl = http://localhost:8080

### ============================================
### WORKER ENDPOINTS
### ============================================

### Get all workers
GET {{baseUrl}}/workers

### Get worker by ID
GET {{baseUrl}}/workers/1

### Create a new worker
POST {{baseUrl}}/workers
Content-Type: application/json

{
  "workerName": "John",
  "workerLastName": "Doe"
}

### Update a worker
PUT {{baseUrl}}/workers/1
Content-Type: application/json

{
  "workerName": "Jane",
  "workerLastName": "Smith"
}

### Delete a worker
DELETE {{baseUrl}}/workers/1

### ============================================
### TASK STATUS ENDPOINTS
### ============================================

### Get all statuses
GET {{baseUrl}}/statuses

### Create a new status
POST {{baseUrl}}/statuses
Content-Type: application/json

{
  "statusName": "To Do"
}

### Create another status
POST {{baseUrl}}/statuses
Content-Type: application/json

{
  "statusName": "In Progress"
}

### Create completed status
POST {{baseUrl}}/statuses
Content-Type: application/json

{
  "statusName": "Done"
}

### ============================================
### TASK CATEGORY ENDPOINTS
### ============================================

### Get all categories
GET {{baseUrl}}/categories

### Create a new category
POST {{baseUrl}}/categories
Content-Type: application/json

{
  "categoryName": "Work"
}

### Create another category
POST {{baseUrl}}/categories
Content-Type: application/json

{
  "categoryName": "Personal"
}

### ============================================
### USER ENDPOINTS
### ============================================

### Get all users
GET {{baseUrl}}/users

### Create a new user
POST {{baseUrl}}/users
Content-Type: application/json

{
  "userName": "admin",
  "password": "password123",
  "mail": "admin@example.com"
}

### ============================================
### TASK ENDPOINTS
### ============================================

### Get all tasks
GET {{baseUrl}}/tasks

### Create a new task (with relationships)
POST {{baseUrl}}/tasks
Content-Type: application/json

{
  "taskName": "Complete project documentation",
  "dueDate": "2025-11-15",
  "description": "Write comprehensive documentation for the project",
  "worker": {
    "workerId": 1
  },
  "status": {
    "statusId": 1
  },
  "category": {
    "categoryId": 1
  }
}

### Get task by ID
GET {{baseUrl}}/tasks/1

### Update a task
PUT {{baseUrl}}/tasks/1
Content-Type: application/json

{
  "taskName": "Updated task name",
  "dueDate": "2025-11-20",
  "description": "Updated description",
  "worker": {
    "workerId": 1
  },
  "status": {
    "statusId": 2
  },
  "category": {
    "categoryId": 1
  }
}

### Delete a task
DELETE {{baseUrl}}/tasks/1

